{
  "name": "paikea",
  "version": "0.0.4",
  "module": "src/cli/index.ts",
  "type": "module",
  "bin": {
    "paikea": "dist/paikea"
  },
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "build": "bun run build.ts",
    "make:exe": "bun run build.ts --exe",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "check": "bun run typecheck && bun run lint && bun run test"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "@types/react": "^19.2.17",
    "clipse": "^0.0.18",
    "ink": "^7.1.0",
    "react": "^19.2.7",
    "termui": "^1.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/bun": "latest",
    "react-devtools-core": "^7.0.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
