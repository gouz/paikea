{
  "name": "paikea",
  "version": "0.1.0",
  "module": "src/cli/index.ts",
  "type": "module",
  "bin": {
    "paikea": "dist/paikea"
  },
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "build": "bun run build.ts",
    "typecheck": "tsc --noEmit",
